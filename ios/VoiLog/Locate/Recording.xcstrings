    "広告なしで快適に録音・再生" : {

    },
    "日常のメモや短い音声記録に最適。ファイルサイズを抑えた省エネ設定です。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأفضل للملاحظات اليومية والتسجيلات الصوتية القصيرة. موفّر للطاقة مع أحجام ملفات أصغر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
