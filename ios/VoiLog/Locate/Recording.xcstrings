        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "For interviews and reporting. High-quality settings prioritizing voice clarity."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "For interviews and reporting. High-quality settings prioritizing voice clarity."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "للمقابلات والتقارير. إعدادات عالية الجودة تُركّز على وضوح الصوت."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk wawancara dan pelaporan. Pengaturan berkualitas tinggi yang mengutamakan kejernihan suara."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साक्षात्कार और रिपोर्टिंग के लिए। आवाज़ की स्पष्टता को प्राथमिकता देने वाली उच्च-गुणवत्ता सेटिंग।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voor interviews en verslaggeving. Hoogwaardige instellingen met prioriteit voor stemhelderheid."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Do wywiadów i reportaży. Wysokiej jakości ustawienia priorytetyzujące wyrazistość głosu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För intervjuer och rapportering. Högkvalitativa inställningar med fokus på rösttydlighet."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สำหรับการสัมภาษณ์และรายงาน การตั้งค่าคุณภาพสูงที่ให้ความสำคัญกับความชัดเจนของเสียง"
          }
        }
      }
    },
