            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日常のメモや短い音声記録に最適。ファイルサイズを抑えた省エネ設定です。"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Best for daily notes and short voice recordings. Energy-efficient with smaller file sizes."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأفضل للملاحظات اليومية والتسجيلات الصوتية القصيرة. موفّر للطاقة مع أحجام ملفات أصغر."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terbaik untuk catatan harian dan rekaman suara singkat. Hemat energi dengan ukuran file lebih kecil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दैनिक नोट्स और छोटी आवाज़ रिकॉर्डिंग के लिए सर्वश्रेष्ठ। छोटे फ़ाइल आकार के साथ ऊर्जा-कुशल।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beste voor dagelijkse notities en korte spraakopnames. Energiezuinig met kleinere bestandsgroottes."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Najlepsza do codziennych notatek i krótkich nagrań głosowych. Energooszczędna z mniejszymi rozmiarami plików."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bäst för dagliga anteckningar och korta röstinspelningar. Energieffektiv med mindre filstorlekar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ดีที่สุดสำหรับบันทึกประจำวันและการบันทึกเสียงสั้นๆ ประหยัดพลังงานด้วยขนาดไฟล์ที่เล็กกว่า"
          }
        }
      }
    },
    "楽器演奏や音楽録音向け。WAV形式で原音を忠実に記録します。": {
      "localizations": {
        "de": {
          "stringUnit": {
