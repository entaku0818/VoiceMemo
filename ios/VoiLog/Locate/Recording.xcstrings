          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لتسجيل الآلات الموسيقية والموسيقى. يسجّل بتنسيق WAV للحصول على صوت أصلي أمين."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk perekaman instrumen dan musik. Merekam dalam format WAV untuk suara asli yang setia."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वाद्य यंत्र और संगीत रिकॉर्डिंग के लिए। मूल ध्वनि के प्रति वफ़ादार WAV प्रारूप में रिकॉर्ड करता है।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voor instrument- en muziekopnames. Neemt op in WAV-formaat voor een getrouwe originele klank."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Do nagrywania instrumentów i muzyki. Nagrywa w formacie WAV dla wiernego odtworzenia oryginalnego dźwięku."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För instrument- och musikinspelning. Spelar in i WAV-format för ett troget originalljud."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สำหรับบันทึกเครื่องดนตรีและเพลง บันทึกในรูปแบบ WAV เพื่อเสียงต้นฉบับที่แท้จริง"
          }
        }
      }
    },
