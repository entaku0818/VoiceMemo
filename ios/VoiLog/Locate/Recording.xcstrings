    "会議や打ち合わせに最適。複数人の声を聞き取りやすいバランス設定です。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "en": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "会議や打ち合わせに最適。複数人の声を聞き取りやすいバランス設定です。"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ideal for meetings and discussions. Balanced settings for capturing multiple voices clearly."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مثالي للاجتماعات والمناقشات. إعدادات متوازنة لالتقاط أصوات متعددة بوضوح."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ideal untuk rapat dan diskusi. Pengaturan seimbang untuk merekam beberapa suara dengan jelas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैठकों और चर्चाओं के लिए आदर्श। कई आवाज़ों को स्पष्ट रूप से कैप्चर करने के लिए संतुलित सेटिंग।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ideaal voor vergaderingen en discussies. Gebalanceerde instellingen voor het helder opnemen van meerdere stemmen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Idealny do spotkań i dyskusji. Wyważone ustawienia do wyraźnego nagrywania wielu głosów."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Idealisk för möten och diskussioner. Balanserade inställningar för att tydligt fånga upp flera röster."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เหมาะสำหรับการประชุมและการอภิปราย การตั้งค่าที่สมดุลเพื่อบันทึกหลายเสียงได้อย่างชัดเจน"
          }
        }
      }
    },
