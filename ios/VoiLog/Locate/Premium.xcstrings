        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "All your data syncs via iCloud, enabling use across multiple devices!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "All your data syncs via iCloud, enabling use across multiple devices!"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "All your data syncs via iCloud, enabling use across multiple devices!"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتم مزامنة جميع بياناتك عبر iCloud، مما يتيح لك الاستخدام على أجهزة متعددة!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Semua data Anda disinkronkan melalui iCloud, memungkinkan penggunaan di beberapa perangkat!"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका सारा डेटा iCloud के ज़रिए सिंक होता है, जिससे कई डिवाइस पर उपयोग संभव होता है!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Al uw gegevens worden gesynchroniseerd via iCloud, waardoor gebruik op meerdere apparaten mogelijk is!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wszystkie Twoje dane są synchronizowane przez iCloud, umożliwiając korzystanie na wielu urządzeniach!"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "All din data synkroniseras via iCloud, vilket möjliggör användning på flera enheter!"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อมูลทั้งหมดของคุณซิงค์ผ่าน iCloud ช่วยให้ใช้งานได้บนหลายอุปกรณ์!"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 데이터가 iCloud로 동기화되어 여러 기기에서 사용 가능합니다!"
          }
        }
      }
    },
