    "すべてのデータがiCloudで同期され、複数デバイスでの使用が可能に！": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "All your data syncs via iCloud, enabling use across multiple devices!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All your data syncs via iCloud, enabling use across multiple devices!"
