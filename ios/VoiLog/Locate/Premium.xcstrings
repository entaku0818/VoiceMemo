  "strings": {
    "1ヶ月 無料でお試し": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جرّب مجانًا لمدة شهر"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen Monat kostenlos ausprobieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try for one month free"
          }
        },
        "es": {
