        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Create as many playlists as you like (normally limited to 3) to organize your recordings!"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ قوائم تشغيل بلا حدود (عادةً محدودة بـ3) لتنظيم تسجيلاتك!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buat playlist sebanyak yang Anda inginkan (biasanya dibatasi 3) untuk mengatur rekaman Anda!"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी रिकॉर्डिंग व्यवस्थित करने के लिए जितनी चाहें उतनी प्लेलिस्ट बनाएं (सामान्यतः 3 तक सीमित)!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maak zoveel afspeellijsten als u wilt (normaal beperkt tot 3) om uw opnamen te ordenen!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twórz tyle list odtwarzania, ile chcesz (zwykle ograniczone do 3), aby porządkować nagrania!"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skapa så många spellistor du vill (vanligtvis begränsat till 3) för att organisera dina inspelningar!"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สร้างเพลย์ลิสต์ได้ตามต้องการ (ปกติจำกัด 3 รายการ) เพื่อจัดระเบียบการบันทึกของคุณ!"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음을 정리하기 위해 원하는 만큼 플레이리스트를 만드세요 (일반적으로 3개까지)!"
          }
        }
      }
    },
