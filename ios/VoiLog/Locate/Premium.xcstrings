    "7日間の無料トライアル終了後、%@/月で自動的に課金されます。更新日の24時間前までにAppleのサブスクリプション設定からいつでもキャンセルできます。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد انتهاء الفترة التجريبية المجانية لمدة 7 أيام، سيتم تحصيل %@/شهر تلقائيًا. يمكنك الإلغاء في أي وقت من إعدادات الاشتراك في Apple قبل 24 ساعة على الأقل من تاريخ التجديد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem 7-tägigen kostenlosen Testzeitraum werden %@/Monat automatisch abgerechnet. Sie können jederzeit über Apples Abonnementeinstellungen kündigen, mindestens 24 Stunden vor dem Verlängerungsdatum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After the 7-day free trial, you will be charged %@/month automatically. You can cancel anytime from Apple's subscription settings at least 24 hours before the renewal date."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras la prueba gratuita de 7 días, se te cobrará %@/mes automáticamente. Puedes cancelar en cualquier momento desde la configuración de suscripciones de Apple al menos 24 horas antes de la fecha de renovación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après l'essai gratuit de 7 jours, %@/mois vous seront facturés automatiquement. Vous pouvez annuler à tout moment depuis les paramètres d'abonnement d'Apple au moins 24 heures avant la date de renouvellement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "7 दिनों के निःशुल्क परीक्षण के बाद, आपसे %@/माह स्वचालित रूप से शुल्क लिया जाएगा। आप नवीनीकरण तिथि से कम से कम 24 घंटे पहले Apple की सदस्यता सेटिंग से कभी भी रद्द कर सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Setelah uji coba gratis 7 hari, Anda akan dikenakan biaya %@/bulan secara otomatis. Anda dapat membatalkan kapan saja dari pengaturan langganan Apple setidaknya 24 jam sebelum tanggal pembaruan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dopo la prova gratuita di 7 giorni, verranno addebitati %@/mese automaticamente. Puoi annullare in qualsiasi momento dalle impostazioni di abbonamento di Apple almeno 24 ore prima della data di rinnovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "7日間の無料トライアル終了後、%@/月で自動的に課金されます。更新日の24時間前までにAppleのサブスクリプション設定からいつでもキャンセルできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "7일 무료 체험 후 %@/월이 자동으로 청구됩니다. 갱신일 24시간 전까지 Apple 구독 설정에서 언제든지 취소할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na de gratis proefperiode van 7 dagen wordt u automatisch %@/maand in rekening gebracht. U kunt op elk moment annuleren via de abonnementsinstellingen van Apple, ten minste 24 uur voor de verlengingsdatum."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Po 7-dniowym bezpłatnym okresie próbnym będziesz automatycznie obciążany kwotą %@/miesiąc. Możesz anulować w dowolnym momencie w ustawieniach subskrypcji Apple, co najmniej 24 godziny przed datą odnowienia."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Após o período de avaliação gratuita de 7 dias, serão cobrados %@/mês automaticamente. Pode cancelar a qualquer momento nas definições de subscrição da Apple, pelo menos 24 horas antes da data de renovação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После 7-дневного бесплатного пробного периода с вас будет автоматически списываться %@/месяц. Вы можете отменить подписку в любое время в настройках подписок Apple не менее чем за 24 часа до даты продления."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Efter den 7 dagars kostnadsfria provperioden debiteras du automatiskt %@/månad. Du kan avbryta när som helst via Apples prenumerationsinställningar minst 24 timmar före förnyelsedatumet."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หลังจากทดลองใช้ฟรี 7 วัน คุณจะถูกเรียกเก็บเงิน %@/เดือนโดยอัตโนมัติ คุณสามารถยกเลิกได้ทุกเมื่อจากการตั้งค่าการสมัครสมาชิกของ Apple อย่างน้อย 24 ชั่วโมงก่อนวันต่ออายุ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "7 günlük ücretsiz deneme süresinin ardından %@/ay otomatik olarak ücretlendirileceksiniz. Apple'ın abonelik ayarlarından yenileme tarihinden en az 24 saat önce istediğiniz zaman iptal edebilirsiniz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sau thời gian dùng thử miễn phí 7 ngày, bạn sẽ bị tính phí %@/tháng tự động. Bạn có thể hủy bất cứ lúc nào từ cài đặt đăng ký của Apple ít nhất 24 giờ trước ngày gia hạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "7天免费试用结束后，将自动收取%@/月的费用。您可以在续订日期前24小时内随时通过Apple订阅设置取消。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "7天免費試用結束後，將自動收取%@/月的費用。您可以在續訂日期前24小時內隨時透過Apple訂閱設定取消。"
          }
        }
      }
    },
