    "サブスクリプションに登録すると、文字起こし結果から要約とTODOを自動生成できます。" : {
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "اشترك لإنشاء ملخصات ومهام تلقائياً من نتائج النسخ." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Abonnieren Sie, um automatisch Zusammenfassungen und TODOs aus Transkriptionsergebnissen zu erstellen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Subscribe to automatically generate summaries and TODOs from your transcription results." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Suscríbete para generar automáticamente resúmenes y TODOs a partir de los resultados de la transcripción." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Abonnez-vous pour générer automatiquement des résumés et des TODOs à partir de vos résultats de transcription." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "ट्रांसक्रिप्शन परिणामों से स्वचालित रूप से सारांश और TODO जनरेट करने के लिए सदस्यता लें।" } },
        "id" : { "stringUnit" : { "state" : "translated", "value" : "Berlangganan untuk membuat ringkasan dan TODO secara otomatis dari hasil transkripsi." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Abbonati per generare automaticamente riepiloghi e TODO dai risultati della trascrizione." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "サブスクリプションに登録すると、文字起こし結果から要約とTODOを自動生成できます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "구독하면 문자 변환 결과에서 요약과 TODO를 자동 생성할 수 있습니다." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Abonneer u om automatisch samenvattingen en taken te genereren uit transcriptieresultaten." } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Subskrybuj, aby automatycznie generować podsumowania i TODO z wyników transkrypcji." } },
        "pt-PT" : { "stringUnit" : { "state" : "translated", "value" : "Subscreva para gerar automaticamente resumos e TODOs a partir dos resultados da transcrição." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подпишитесь, чтобы автоматически создавать резюме и задачи из результатов транскрипции." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Prenumerera för att automatiskt generera sammanfattningar och TODOs från transkriptionsresultat." } },
        "th" : { "stringUnit" : { "state" : "translated", "value" : "สมัครสมาชิกเพื่อสร้างสรุปและ TODO จากผลการถอดความโดยอัตโนมัติ" } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Transkripsiyon sonuçlarından otomatik olarak özet ve TODO oluşturmak için abone olun." } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Đăng ký để tự động tạo tóm tắt và TODO từ kết quả phiên âm." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "订阅后，可从转录结果自动生成摘要和TODO。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "訂閱後，可從轉錄結果自動生成摘要和TODO。" } }
