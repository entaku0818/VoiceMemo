    "チュートリアルをスキップしますか？\n後で設定画面から再度確認できます。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد تخطي التعليمي؟\nيمكنك عرضه مرة أخرى لاحقاً في الإعدادات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutorial überspringen?\nSie können es später in den Einstellungen erneut ansehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip the tutorial?\nYou can view it again later in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Omitir el tutorial?\nPuede verlo nuevamente en Configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passer le tutoriel ?\nVous pourrez le revoir dans les Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ट्यूटोरियल छोड़ें?\nआप इसे बाद में सेटिंग से फिर देख सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lewati tutorial?\nAnda dapat melihatnya lagi nanti di Pengaturan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Saltare il tutorial?\nPuoi rivederlo nelle Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チュートリアルをスキップしますか？\n後で設定画面から再度確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "튜토리얼을 건너뛰시겠습니까?\n나중에 설정에서 다시 볼 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutorial overslaan?\nJe kunt het later opnieuw bekijken in Instellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pominąć samouczek?\nMożesz go obejrzeć ponownie w Ustawieniach."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pular o tutorial?\nVocê pode vê-lo novamente em Configurações."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignorar o tutorial?\nPode vê-lo novamente nas Definições."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропустить обучение?\nВы можете просмотреть его позже в Настройках."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoppa över guiden?\nDu kan se den igen senare i Inställningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้ามบทเรียนหรือไม่?\nคุณสามารถดูอีกครั้งได้ในการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Öğreticiyi atla?\nDaha sonra Ayarlar'dan tekrar görüntüleyebilirsiniz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bỏ qua hướng dẫn?\nBạn có thể xem lại trong Cài đặt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳过教程？\n您可以稍后在设置中再次查看。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "略過教學？\n您可以稍後在設定中再次查看。"
          }
        }
      }
    },
