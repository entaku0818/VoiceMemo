    "次の画面のメールにて詳細に状況を教えてください。": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى وصف التفاصيل في البريد الإلكتروني على الشاشة التالية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
