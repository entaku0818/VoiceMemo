    "Permission is required to record voice memos": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مطلوب الإذن لتسجيل المذكرات الصوتية"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubnis ist erforderlich, um Sprachnotizen aufzunehmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permission is required to record voice memos"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere permiso para grabar notas de voz."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une autorisation est nécessaire pour enregistrer des mémos vocaux."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वॉइस मेमो रिकॉर्ड करने के लिए अनुमति आवश्यक है"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izin diperlukan untuk merekam memo suara"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È necessaria l'autorizzazione per registrare i memo vocali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声メモを録音するには許可が必要です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성 메모를 녹음하려면 권한이 필요합니다"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toestemming vereist om spraaknotities op te nemen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymagane jest pozwolenie do nagrywania notatek głosowych"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "É necessário permissão para gravar notas de voz."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется разрешение для записи голосовых заметок."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Behörighet krävs för att spela in röstanteckningar"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ต้องการสิทธิ์ในการบันทึกบันทึกเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesli not kaydetmek için izin gereklidir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần có quyền để ghi âm ghi chú bằng giọng nói."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要权限来录制语音备忘录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錄製語音備忘錄需要許可。"
          }
        }
      }
    },
