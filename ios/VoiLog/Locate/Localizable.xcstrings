    "今日どんな1日でしたか？声で残す時間です 🎙": {
      "comment": "Daily reminder notification body",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie war dein Tag? Zeit, ihn mit deiner Stimme festzuhalten 🎙"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How was your day? Time to capture it in your voice 🎙"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo fue tu día? Es hora de capturarlo con tu voz 🎙"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment s'est passée votre journée ? Il est temps de la capturer avec votre voix 🎙"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Com'è andata oggi? È il momento di catturarla con la tua voce 🎙"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日どんな1日でしたか？声で残す時間です 🎙"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Como foi o seu dia? É hora de captá-lo com a sua voz 🎙"
          }
        },
        "ru": {
          "stringUnit": {
