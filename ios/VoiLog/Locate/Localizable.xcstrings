        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Rekaman ini tidak berisi data transkripsi.\nAkan dibuat secara otomatis saat melakukan rekaman baru."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa registrazione non contiene dati di trascrizione.\nVerranno generati automaticamente quando effettuerai una nuova registrazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この録音には文字起こしデータが含まれていません。\n新しい録音を行うと自動的に生成されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 녹음에는 문자 변환 데이터가 없습니다.\n새 녹음을 하면 자동으로 생성됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze opname bevat geen transcriptiegegevens.\nDeze worden automatisch aangemaakt bij een nieuwe opname."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To nagranie nie zawiera danych transkrypcji.\nZostaną one wygenerowane automatycznie przy nowym nagraniu."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta gravação não contém dados de transcrição.\nSerão gerados automaticamente quando fizer uma nova gravação."
          }
        },
        "ru": {
