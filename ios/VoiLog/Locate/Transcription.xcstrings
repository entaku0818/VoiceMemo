    "サーバーが混雑しています。しばらく待ってから再試行してください。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الخادم مشغول. يرجى الانتظار قليلاً ثم المحاولة مجدداً."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Server sedang sibuk. Tunggu sebentar lalu coba lagi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर व्यस्त है। कृपया थोड़ी देर प्रतीक्षा करें और पुनः प्रयास करें।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De server is bezet. Wacht even en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Serwer jest zajęty. Poczekaj chwilę i spróbuj ponownie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Servern är upptagen. Vänta en stund och försök igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซิร์ฟเวอร์ไม่ว่าง โปรดรอสักครู่แล้วลองอีกครั้ง"
          }
        }
      }
    },
    "サーバーエラーが発生しました。再試行してください。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدث خطأ في الخادم. يرجى المحاولة مجدداً."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terjadi kesalahan server. Silakan coba lagi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर त्रुटि हुई। कृपया पुनः प्रयास करें।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is een serverfout opgetreden. Probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wystąpił błąd serwera. Spróbuj ponownie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ett serverfel inträffade. Försök igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เกิดข้อผิดพลาดของเซิร์ฟเวอร์ โปรดลองอีกครั้ง"
          }
        }
      }
    },
    "リクエストが多すぎます。しばらく待ってから再試行してください。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "طلبات كثيرة جداً. يرجى الانتظار قليلاً ثم المحاولة مجدداً."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terlalu banyak permintaan. Tunggu sebentar lalu coba lagi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बहुत अधिक अनुरोध हैं। कृपया थोड़ी देर प्रतीक्षा करें और पुनः प्रयास करें।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Te veel verzoeken. Wacht even en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zbyt wiele żądań. Poczekaj chwilę i spróbuj ponownie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För många förfrågningar. Vänta en stund och försök igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำขอมากเกินไป โปรดรอสักครู่แล้วลองอีกครั้ง"
          }
        }
      }
    },
