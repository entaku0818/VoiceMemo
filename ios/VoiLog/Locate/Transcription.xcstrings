    "通常2〜5分かかります。このまましばらくお待ちください。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies dauert normalerweise 2–5 Minuten. Bitte warten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This usually takes 2–5 minutes. Please wait."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto suele tardar 2–5 minutos. Por favor, espera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela prend généralement 2–5 minutes. Veuillez patienter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Di solito ci vogliono 2–5 minuti. Attendere prego."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Geralmente demora 2–5 minutos. Por favor, aguarde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обычно это занимает 2–5 минут. Пожалуйста, подождите."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu genellikle 2–5 dakika sürer. Lütfen bekleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thường mất 2–5 phút. Vui lòng chờ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通常需要2–5分钟，请稍候。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "通常需要2–5分鐘，請稍候。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستغرق هذا عادةً 2–5 دقائق. يرجى الانتظار."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini biasanya membutuhkan 2–5 menit. Harap tunggu."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसमें आमतौर पर 2–5 मिनट लगते हैं। कृपया प्रतीक्षा करें।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
