    "サーバーが混雑しています。しばらく待ってから再試行してください。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server ist überlastet. Bitte warten Sie einen Moment und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server is busy. Please wait a moment and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor está ocupado. Espera un momento y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur est occupé. Veuillez patienter un moment puis réessayer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server è occupato. Attendi un momento e riprova."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O servidor está ocupado. Aguarde um momento e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервер перегружен. Подождите немного и повторите попытку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sunucu meşgul. Lütfen bir süre bekleyin ve tekrar deneyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Máy chủ đang bận. Vui lòng chờ một lúc và thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器繁忙，请稍候再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器繁忙，請稍候再試。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الخادم مشغول. يرجى الانتظار قليلاً ثم المحاولة مجدداً."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Server sedang sibuk. Tunggu sebentar lalu coba lagi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर व्यस्त है। कृपया थोड़ी देर प्रतीक्षा करें और पुनः प्रयास करें।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De server is bezet. Wacht even en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Serwer jest zajęty. Poczekaj chwilę i spróbuj ponownie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Servern är upptagen. Vänta en stund och försök igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซิร์ฟเวอร์ไม่ว่าง โปรดรอสักครู่แล้วลองอีกครั้ง"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서버가 혼잡합니다. 잠시 후 다시 시도해 주세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
