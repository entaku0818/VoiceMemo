    "いただいたサポートは開発費用として大切に利用させていただきます。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Unterstützung wird sehr geschätzt und als Entwicklungskosten verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your support will be greatly appreciated and used as development costs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su apoyo será muy apreciado y utilizado como costos de desarrollo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre soutien sera grandement apprécié et utilisé pour les coûts de développement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo sostegno sarà molto apprezzato e utilizzato per i costi di sviluppo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いただいたサポートは開発費用として大切に利用させていただきます。"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu apoio será muito apreciado e utilizado como custos de desenvolvimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша поддержка будет очень признательна и использована на разработку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Destekleriniz büyük takdir toplayacak ve geliştirme maliyeti olarak kullanılacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sự hỗ trợ của bạn sẽ được đánh giá cao và sử dụng như chi phí phát triển."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的支持将被非常感谢并作为开发费用使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您的支持將被非常感謝並作為開發費用使用。"
          }
        },
