    "いただいたサポートは開発費用として大切に利用させていただきます。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم استخدام دعمك بشكل كبير وتقديره كتكاليف تطوير."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Unterstützung wird sehr geschätzt und als Entwicklungskosten verwendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your support will be greatly appreciated and used as development costs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su apoyo será muy apreciado y utilizado como costos de desarrollo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre soutien sera grandement apprécié et utilisé pour les coûts de développement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके सहयोग की अत्यधिक सराहना की जाएगी और इसे विकास लागत के रूप में उपयोग किया जाएगा।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
