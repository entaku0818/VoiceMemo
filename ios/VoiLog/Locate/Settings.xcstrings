        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여러분의 지원은 개발 비용으로 소중히 사용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uw steun wordt zeer gewaardeerd en gebruikt als ontwikkelingskosten."
