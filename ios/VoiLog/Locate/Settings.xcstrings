    "いただいたサポートは開発費用として大切に利用させていただきます。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Unterstützung wird sehr geschätzt und als Entwicklungskosten verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your support will be greatly appreciated and used as development costs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su apoyo será muy apreciado y utilizado como costos de desarrollo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre soutien sera grandement apprécié et utilisé pour les coûts de développement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo sostegno sarà molto apprezzato e utilizzato per i costi di sviluppo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いただいたサポートは開発費用として大切に利用させていただきます。"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu apoio será muito apreciado e utilizado como custos de desenvolvimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша поддержка будет очень признательна и использована на разработку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Destekleriniz büyük takdir toplayacak ve geliştirme maliyeti olarak kullanılacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sự hỗ trợ của bạn sẽ được đánh giá cao và sử dụng như chi phí phát triển."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的支持将被非常感谢并作为开发费用使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您的支持將被非常感謝並作為開發費用使用。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم استخدام دعمك بشكل كبير وتقديره كتكاليف تطوير."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dukungan Anda akan sangat dihargai dan digunakan sebagai biaya pengembangan."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके सहयोग की अत्यधिक सराहना की जाएगी और इसे विकास लागत के रूप में उपयोग किया जाएगा।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw steun wordt zeer gewaardeerd en gebruikt als ontwikkelingskosten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje wsparcie zostanie bardzo docenione i wykorzystane jako koszty rozwoju."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ditt stöd uppskattas mycket och används som utvecklingskostnader."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การสนับสนุนของคุณจะได้รับการยกย่องอย่างสูงและนำไปใช้เป็นค่าใช้จ่ายในการพัฒนา"
          }
        }
      }
    },
    "ご支援いただける場合は次の画面で購入お願いいたします。開発費用に利用させていただきます。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie Unterstützung leisten möchten, tätigen Sie bitte einen Kauf auf dem nächsten Bildschirm. Die Unterstützung wird für die Entwicklungskosten verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you wish to provide support, please make a purchase on the next screen. The support will be used for development costs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si desea brindar apoyo, realice una compra en la siguiente pantalla. El apoyo se utilizará para los costos de desarrollo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous souhaitez apporter votre soutien, veuillez effectuer un achat sur l'écran suivant. Le soutien sera utilisé pour les coûts de développement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se desideri fornire supporto, effettua un acquisto nella prossima schermata. Il supporto verrà utilizzato per i costi di sviluppo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご支援いただける場合は次の画面で購入お願いいたします。開発費用に利用させていただきます。"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Se desejar fornecer suporte, faça uma compra na próxima tela. O suporte será usado para os custos de desenvolvimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если вы хотите оказать поддержку, пожалуйста, совершите покупку на следующем экране. Поддержка будет использована для разработки."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Destek sağlamak istiyorsanız, lütfen bir sonraki ekranda bir satın alma işlemi yapın. Bu destek, geliştirme maliyetleri için kullanılacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu bạn muốn hỗ trợ, vui lòng thực hiện mua hàng trên màn hình tiếp theo. Sự hỗ trợ sẽ được sử dụng cho chi phí phát triển."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您希望提供支持，请在下一个屏幕上购买。支持将用于开发费用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果您希望提供支持，請在下一個屏幕上購買。支持將用於開發費用。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا كنت ترغب في تقديم الدعم، يرجى إجراء عملية شراء في الشاشة التالية. سيتم استخدام الدعم في تكاليف التطوير."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika Anda ingin memberikan dukungan, silakan lakukan pembelian di layar berikutnya. Dukungan akan digunakan untuk biaya pengembangan."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि आप सहयोग प्रदान करना चाहते हैं, तो कृपया अगली स्क्रीन पर खरीदारी करें। सहयोग विकास लागत के लिए उपयोग किया जाएगा।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u ondersteuning wilt bieden, maak dan een aankoop op het volgende scherm. De ondersteuning wordt gebruikt voor ontwikkelingskosten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli chcesz udzielić wsparcia, dokonaj zakupu na następnym ekranie. Wsparcie zostanie wykorzystane na koszty rozwoju."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om du vill ge stöd, gör ett köp på nästa skärm. Stödet kommer att användas för utvecklingskostnader."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากคุณต้องการให้การสนับสนุน โปรดทำการซื้อในหน้าจอถัดไป การสนับสนุนจะนำไปใช้เป็นค่าใช้จ่ายในการพัฒนา"
          }
        }
      }
    },
